const endpoint = {
  method: 'POST',
  path: '/wallet/authenticate',
  baseUrl: 'https://rgs.stake-engine.com',
  title: 'Authenticate',
  description: 'Authenticate a wallet session and retrieve balance, game configuration, and jurisdiction settings.',
  params: [
    {
      name: 'sessionID',
      type: 'string',
      location: 'body',
      required: true,
      description: 'The session ID issued by the operator platform.',
      example: ''
    }
  ],
  responses: [
    {
      status: 200,
      statusText: 'OK',
      description: 'Session authenticated successfully. Returns current balance, active round (if any), and game configuration.',
      exampleBody: JSON.stringify({
        balance: {
          amount: 1000000000,
          currency: "USD"
        },
        round: null,
        config: {
          gameID: "",
          minBet: 100000,
          maxBet: 10000000,
          stepBet: 100000,
          defaultBetLevel: 1000000,
          betLevels: [
            100000, 200000, 400000, 600000, 800000,
            1000000, 1200000, 1400000, 1600000, 1800000,
            2000000, 3000000, 4000000, 5000000, 6000000,
            7000000, 8000000, 9000000, 10000000
          ],
          betModes: {},
          jurisdiction: {
            socialCasino: false,
            disabledFullscreen: false,
            disabledTurbo: false,
            disabledSuperTurbo: false,
            disabledAutoplay: false,
            disabledSlamstop: false,
            disabledSpacebar: false,
            disabledBuyFeature: false,
            displayNetPosition: false,
            displayRTP: false,
            displaySessionTimer: false,
            minimumRoundDuration: 0
          }
        },
        meta: null
      })
    },
    {
      status: 401,
      statusText: 'Unauthorized',
      description: 'The session ID is missing, expired, or invalid.',
      exampleBody: JSON.stringify({
        error: "ERR_IS",
        message: "Invalid or expired sessionID."
      })
    },
    {
      status: 500,
      statusText: 'Internal Server Error',
      description: 'An unexpected error occurred on the server.',
      exampleBody: JSON.stringify({
        error: "ERR_GEN",
        message: "An unexpected error occurred. Please try again later."
      })
    }
  ]
};
