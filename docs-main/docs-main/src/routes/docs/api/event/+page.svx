const endpoint = {
  method: 'POST',
  path: '/bet/event',
  baseUrl: 'https://rgs.stake-engine.com',
  title: 'Event',
  description: 'Track in-progress player actions during a round for state recovery.',
  params: [
    {
      name: 'sessionID',
      type: 'string',
      location: 'body',
      required: true,
      description: 'The session ID issued by the operator platform.',
      example: ''
    },
    {
      name: 'event',
      type: 'string',
      location: 'body',
      required: true,
      description: 'The event identifier representing the player action to track.',
      example: ''
    }
  ],
  responses: [
    {
      status: 200,
      statusText: 'OK',
      description: 'Event tracked successfully.',
      exampleBody: JSON.stringify({
        event: "event_id_here"
      })
    },
    {
      status: 401,
      statusText: 'Unauthorized',
      description: 'The session ID is missing, expired, or invalid.',
      exampleBody: JSON.stringify({
        error: "ERR_IS",
        message: "Invalid or expired sessionID."
      })
